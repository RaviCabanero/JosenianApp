rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null &&
        (request.auth.uid == userId ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin');
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';

      match /posts/{postId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update, delete: if request.auth != null &&
          (request.auth.uid == userId ||
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin');
      }

      match /notifications/{notificationId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }

      // Points history — append-only, readable by owner
      match /pointsHistory/{historyId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
        allow update, delete: if false;
      }
    }

    // ── Departments ──────────────────────────────────────────
    match /departments/{departmentId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
      allow update: if request.auth != null && (
        // Admin/HOD can update anything
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in ['admin', 'hod'] ||
        // Any authenticated user can join a department (adds to members array)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
      );

      // Department Events
      match /events/{eventId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in ['admin', 'hod'];
        allow update: if request.auth != null && (
          // Admin/HOD can update anything (edit form, pin, QR token)
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in ['admin', 'hod'] ||
          // Any authenticated user can join/leave (attendees) or trigger attendance count increment
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attendees', 'attendanceCount'])
        );

        // Attendance subcollection
        match /attendance/{attendeeId} {
          // HOD/admin see all; members see their own record only
          allow read: if request.auth != null &&
            (request.auth.uid == attendeeId ||
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in ['admin', 'hod']);
          // Members write their own attendance via QR scan
          allow create: if request.auth != null && request.auth.uid == attendeeId;
          allow update, delete: if false;
        }
      }

      // Department Wall
      match /wall/{postId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null && (
          // Author or admin/HOD can edit content
          resource.data.authorId == request.auth.uid ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in ['admin', 'hod'] ||
          // Any authenticated user can toggle likes
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
        );
        allow delete: if request.auth != null &&
          (resource.data.authorId == request.auth.uid ||
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in ['admin', 'hod']);
      }
    }

    // ── Global Events (top-level, managed by admin) ──────────
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
      allow update: if request.auth != null && (
        // Admin can update anything
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin' ||
        // Any authenticated user can join/leave or trigger attendance count
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attendees', 'attendanceCount'])
      );

      // Attendance subcollection
      match /attendance/{attendeeId} {
        allow read: if request.auth != null &&
          (request.auth.uid == attendeeId ||
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin');
        allow create: if request.auth != null && request.auth.uid == attendeeId;
        allow update, delete: if false;
      }
    }

    // ── Alumni ───────────────────────────────────────────────
    match /alumni/{alumniId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

  }
}
