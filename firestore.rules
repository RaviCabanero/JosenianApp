rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow all read/write for development
    match /users/{userId} {
      allow read, write;
      
      // Posts subcollection - allow all for development
      match /posts/{postId} {
        allow read, write;
      }
      
      // Notifications subcollection
      match /notifications/{notificationId} {
        allow read, write;
      }
    }
    
    // Departments collection
    match /departments/{departmentId} {
      allow read, write;

      // Events subcollection
      match /events/{eventId} {
        allow read, write;
      }

      // Wall (freedom wall) subcollection
      match /wall/{postId} {
        allow read, write;
      }
    }
    
    // Events collection (top-level)
    match /events/{eventId} {
      allow read, write;
    }

    // Alumni collection
    match /alumni/{alumniId} {
      allow read, write;
    }
  }
}
