rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write;

      match /posts/{postId} {
        allow read, write;
      }

      match /notifications/{notificationId} {
        allow read, write;
      }

      match /pointsHistory/{historyId} {
        allow read, write;
      }

      match /friendRequests/{requestId} {
        allow read, write;
      }
    }

    match /departments/{departmentId} {
      allow read, write;

      match /events/{eventId} {
        allow read, write;

        match /attendance/{attendeeId} {
          allow read, write;
        }
      }

      match /wall/{postId} {
        allow read, write;
      }
    }

    match /events/{eventId} {
      allow read, write;

      match /attendance/{userId} {
        allow read, write;
      }
    }

    match /alumni/{alumniId} {
      allow read, write;
    }

    match /conversations/{conversationId} {
      allow read, write;

      match /messages/{messageId} {
        allow read, write;
      }
    }
  }
}
